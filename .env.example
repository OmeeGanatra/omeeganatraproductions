# ─────────────────────────────────────────────────────────────────────────────
# Omee Ganatra Productions — environment template
#
# Copy this file to .env for local development. .env is gitignored.
# In production, set these as real environment variables (e.g. Vercel +
# Railway dashboards). The server refuses to start in production if any
# secret here is left at its dev placeholder.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV="development"
PORT=4000

# Database (Postgres) — Railway add-on or Neon
DATABASE_URL="postgresql://ogp:ogp_secret@localhost:5432/ogp_dev"

# Cache + BullMQ queue (Railway Redis add-on or Upstash)
REDIS_URL="redis://localhost:6379"

# Auth — JWT secrets MUST be ≥32 chars and changed in production.
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET="dev-access-secret-change-in-production-min32chars!!"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-min32chars!"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY_DAYS=14

# Object storage. Works with AWS S3, Cloudflare R2, Backblaze B2, or MinIO.
# For Cloudflare R2:
#   AWS_REGION="auto"
#   AWS_S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
#   AWS_S3_FORCE_PATH_STYLE="true"
#   AWS_CLOUDFRONT_DOMAIN="<bucket>.<accountid>.r2.cloudflarestorage.com"
# Local (MinIO via docker compose):
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="ogp-media"
AWS_S3_ENDPOINT="http://localhost:9000"
AWS_S3_FORCE_PATH_STYLE="true"
AWS_CLOUDFRONT_DOMAIN="localhost:4000"

# Email — pick one provider
EMAIL_PROVIDER="resend"            # "resend" | "ses"
EMAIL_FROM="noreply@omeeganatra.com"

# Resend (https://resend.com) — required if EMAIL_PROVIDER=resend
RESEND_API_KEY=""

# Web origins
CORS_ORIGIN="http://localhost:3000"
APP_URL="http://localhost:3000"

# Next.js — exposed to the browser
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
